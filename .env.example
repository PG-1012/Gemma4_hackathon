# Copy to .env and fill in. Defaults run fully offline with the mock provider.

# Provider: mock | cerebras | anthropic
LLM_PROVIDER=mock

# --- Cerebras (confirm exact values at hackathon kickoff) ---
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# TODO: set to the exact Gemma multimodal model id Cerebras serves
CEREBRAS_MODEL=gemma-vision-TODO

# --- Anthropic fallback (optional) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Browser ---
HEADLESS=false
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=900
FORM_URL=http://localhost:8000/web/expense-form.html

# --- Orchestration ---
MAX_RETRIES=2
SKIP_SAFE_VERIFY=true
USE_MARKS=true
